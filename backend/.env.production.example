# Production .env-Vorlage fuer Hetzner-Server
# Kopieren nach /opt/tc-much-app/.env auf 91.99.164.240
# JWT-Secrets via `openssl rand -hex 32` generieren!

PORT=3001
NODE_ENV=production
API_URL=https://app-api.tcmuch.de

DATABASE_URL=postgresql://tcmuch_app:CHANGE_ME@localhost:5432/tcmuch_app

JWT_ACCESS_SECRET=CHANGE_ME_64_HEX_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_64_HEX_CHARS
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

CORS_ORIGIN=https://app-api.tcmuch.de,https://tcmuch.de,https://admin.tcmuch.de

UPLOAD_DIR=/opt/tc-much-app/uploads
MAX_FILE_SIZE=5242880

# Webhook-Secret fuer Admin-Panel -> App-Backend Push (Schritt 7 der Roadmap)
WEBHOOK_SECRET=CHANGE_ME_64_HEX_CHARS

# Website-API als Source of Truth fuer News + Club-Events (Schritt 4 der Roadmap)
WEBSITE_API_URL=https://api.tcmuch.de

EXPO_ACCESS_TOKEN=
